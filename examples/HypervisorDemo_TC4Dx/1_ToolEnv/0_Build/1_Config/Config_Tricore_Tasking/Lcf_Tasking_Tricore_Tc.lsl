                select ".zrodata.Cpu5_Main_Vm6.*";
                select ".zrodata.Cpu5_Main_Vm7.*";

                /*Near Absolute Const, selectable by toolchain*/
                select ".zrodata.const.cpu0.32bit";
                select ".zrodata.const.cpu0.16bit";
                select ".zrodata.const.cpu0.8bit";
                select ".zrodata.config.cpu0.32bit";
                select ".zrodata.config.cpu0.16bit";
                select ".zrodata.config.cpu0.8bit";
                select "(.zrodata|.zrodata.*)";
            }
        }
    }

    /*Relative A0/A1/A8/A9 Addressable Sections*/
    section_layout :vtc:linear
    {
        /*Relative A0 Addressable Data, selectable by toolchain*/
        #        if LCF_DEFAULT_HOST == LCF_CPU5
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram50)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU4
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram40)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU3
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram30)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU2
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram20)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU1
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram10)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU0
        group a0 (ordered, contiguous, align = 4, attributes=rw, run_addr = mem:dsram00)
        #        endif
        {
            select "(.sdata|.sdata.*)";
            select "(.sbss|.sbss.*)";
            select "(.data_a0|.data_a0.*)";
            select "(.bss_a0|.bss_a0.*)";
        }
        "_SMALL_DATA_" := sizeof(group:a0) > 0 ? addressof(group:a0) : addressof(group:a0) & 0xF0000000 + 32k;
        "__A0_MEM" = "_SMALL_DATA_";

        /*Relative A1 Addressable Const, selectable by toolchain*/
        /*Small constant sections, No option given for CPU specific user sections to make generated code portable across Cpus*/
        #        if LCF_DEFAULT_HOST == LCF_CPU5
        group  a1 (ordered, align = 4, run_addr=mem:pfls50)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU4
        group  a1 (ordered, align = 4, run_addr=mem:pfls40)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU3
        group  a1 (ordered, align = 4, run_addr=mem:pfls30)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU2
        group  a1 (ordered, align = 4, run_addr=mem:pfls20)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU1
        group  a1 (ordered, align = 4, run_addr=mem:pfls10)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU0
        group  a1 (ordered, align = 4, run_addr=mem:pfls00)
        #        endif
        {
            select "(.ldata|.ldata.*)";
            select "(.rodata_a1|.rodata_a1.*)";
        }
        "_LITERAL_DATA_" := sizeof(group:a1) > 0 ? addressof(group:a1) : addressof(group:a1) & 0xF0000000 + 32k;
        "__A1_MEM" = "_LITERAL_DATA_";

        /*Relative A9 Addressable Data, selectable with patterns and user defined sections*/
        group a9 (ordered, align = 4, run_addr=mem:lmuram)
        {
            select "(.data_a9|.data_a9.*)";
            select "(.bss_a9|.bss_a9.*)";
        }
        "_A9_DATA_" := sizeof(group:a9) > 0 ? addressof(group:a9) : addressof(group:a9) & 0xF0000000 + 32k;
        "__A9_MEM" = "_A9_DATA_";

        /*Relative A8 Addressable Const, selectable with patterns and user defined sections*/
        #        if LCF_DEFAULT_HOST == LCF_CPU5
        group  a8 (ordered, align = 4, run_addr=mem:pfls50)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU4
        group  a8 (ordered, align = 4, run_addr=mem:pfls40)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU3
        group  a8 (ordered, align = 4, run_addr=mem:pfls30)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU2
        group  a8 (ordered, align = 4, run_addr=mem:pfls20)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU1
        group  a8 (ordered, align = 4, run_addr=mem:pfls10)
        #        endif
        #        if LCF_DEFAULT_HOST == LCF_CPU0
        group  a8 (ordered, align = 4, run_addr=mem:pfls00)
        #        endif
        {
            select "(.rodata_a8|.rodata_a8.*)";
        }
        {
            select "(.rodata_a8|.rodata_a8.*)";
        }
        "_A8_DATA_" := sizeof(group:a8) > 0 ? addressof(group:a8) : addressof(group:a8) & 0xF0000000 + 32k;
        "__A8_MEM" = "_A8_DATA_";
    }

