#define RESET LCF_STARTPTR_NC_CPU00

#include "tc1v1_8.lsl"

// Specify a multi-core processor environment (mpe)

processor mpe
{
    derivative = tc4D;
}

derivative tc4D
{
    core tc0
    {
        architecture = TC1V1.8;
        space_id_offset = 100;           // add 100 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core tc1 // core 1 TC18
    {
        architecture = TC1V1.8;
        space_id_offset = 200;           // add 200 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core tc2 // core 2 TC18
    {
        architecture = TC1V1.8;
        space_id_offset = 300;           // add 300 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core tc3 // core 3 TC18
    {
        architecture = TC1V1.8;
        space_id_offset = 400;           // add 400 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core tc4 // core 4 TC18
    {
        architecture = TC1V1.8;
        space_id_offset = 500;           // add 500 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core tc5 // core 5 TC18
    {
        architecture = TC1V1.8;
        space_id_offset = 600;           // add 600 to all space IDs in the architecture definition
        copytable_space = vtc:linear;    // use the copy table in the virtual core for 'bss' and initialized data sections
    }

    core vtc
    {
        architecture = TC1V1.8;
        import tc0;                     // add all address spaces of core tc0 to core vtc for linking and locating
        import tc1;                     //                                tc1
        import tc2;                     //                                tc2
        import tc3;                     //                                tc3
        import tc4;                     //                                tc4
        import tc5;                     //                                tc5
    }

    bus sri
    {
        mau = 8;
        width = 32;

        // map shared addresses one-to-one to real cores and virtual cores
        map (dest=bus:tc0:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:tc1:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:tc2:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:tc3:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:tc4:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:tc5:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
        map (dest=bus:vtc:fpi_bus, src_offset=0, dest_offset=0, size=0xc0000000);
    }

    memory dsram50 // Data Scratch Pad Ram
    {
        mau = 8;
        size = 30k;
        type = ram;
        map (dest=bus:tc5:fpi_bus, dest_offset=0xd0034800, size=30k, priority=8);
        map (dest=bus:sri, dest_offset=0x20034800, size=30k);
    }

    memory psram50 // Program Scratch Pad Ram
    {
        mau = 8;
        size = 8k;
        type = ram;
        map (dest=bus:tc5:fpi_bus, dest_offset=0xc000e000, size=8k, priority=8);
        map (dest=bus:sri, dest_offset=0x2010e000, size=8k);
    }

    memory pfls50
    {
        mau = 8;
        size = 256k;
        type = rom;
        map     cached (dest=bus:sri, dest_offset=0x81200000,           size=256k);
        map not_cached (dest=bus:sri, dest_offset=0xa1200000, reserved, size=256k);
    }

    memory dsram51 // Data Scratch Pad Ram
    {
        mau = 8;
        size = 30k;
        type = ram;
        map (dest=bus:tc5:fpi_bus, dest_offset=0xd002d000, size=30k, priority=8);
        map (dest=bus:sri, dest_offset=0x2002d000, size=30k);
    }

    memory psram51 // Program Scratch Pad Ram
    {
        mau = 8;
